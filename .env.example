# Local mode is the default and requires no credentials.
ED_FLOW_BACKEND=local
ED_FLOW_MODEL_PROVIDER=mock
ED_FLOW_SYNTHETIC_DATA_DIR=data/synthetic
ED_FLOW_DEFAULT_FACILITY=Stollery Children's Hospital
ED_FLOW_DEFAULT_PEDIATRIC_ONLY=true

# Optional Snowflake local development settings.
# Do not commit real credentials or private endpoints.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=WH_SMALL
SNOWFLAKE_DATABASE=DB_TEAM_STOLLERY_AND_ALBERTA_CHILDRENS_HOSPITAL_ANALYTICS
SNOWFLAKE_SCHEMA=MSB_CLINICAL_GENETICS

# Optional model layer. Local prototype works with mock/no model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

